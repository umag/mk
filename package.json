{
  "name": "may-kaiten",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A self-hosted personal kanban canvas — many boards in one space, one keystroke to advance.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gate": "tsc --noEmit && vitest run",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "@types/node": "^26.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.1.1"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.0.21",
    "@fontsource-variable/inter": "^5.0.18",
    "@fontsource-variable/jetbrains-mono": "^5.0.20"
  }
}
